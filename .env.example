# ---- Server ----
PORT=3000
NODE_ENV=development
# Comma-separated browser origins allowed to call the API when NODE_ENV=production
# (the rider & driver PWAs). Ignored in development, where CORS is permissive.
CORS_ORIGINS=http://localhost:8081,http://localhost:8082

# ---- Database: PostgreSQL 16 + PostGIS (single Postgres, spatial ext enabled) ----
# Local Node uses localhost; inside docker-compose the backend uses host `db`.
DATABASE_URL=postgres://ridenow:ridenow@localhost:5432/ridenow

# ---- Payments: Stripe (TEST mode is LIVE; use test cards). Behind a Payment port ----
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# ---- SMS/OTP: Twilio (trial sends only to VERIFIED numbers -> OTP is ALSO logged in dev) ----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---- Maps/geocode/routing: FREE, keyless OpenStreetMap is the default ----
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
# Google Maps key exists but billing is OFF -> leave unset so we default to OSM.
GOOGLE_MAPS_API_KEY=
